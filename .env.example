# Secrets: loaded from macOS Keychain if not set here.
#   TELEGRAM_BOT_TOKEN  ← keychain service 'svarog-telegram-token'
#   ANTHROPIC_AUTH_TOKEN ← keychain service 'Claude Code-credentials' (auto-parsed)
# To store manually:
#   security add-generic-password -s 'svarog-telegram-token' -a 'svarog' -w 'YOUR_TOKEN'
# Or set in env:
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# ANTHROPIC_AUTH_TOKEN=sk-ant-oat01-...

# Allowed Telegram user IDs (comma-separated)
TELEGRAM_ALLOWED_USERS=123456789

# Projects directory to scan
PROJECTS_DIR=~/projects

# Database path
DB_PATH=./data/svarog.db

# Health endpoint port
HEALTH_PORT=3847

# Worker timeouts
WATCHDOG_INTERVAL_MS=1500
WORKER_IDLE_TIMEOUT_S=300
WORKER_SESSION_TIMEOUT_S=7200
WORKER_RESUME_MAX_AGE_S=3600

# Log level (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info

# Timezone for scheduled tasks (e.g., America/New_York, Europe/London)
USER_TIMEZONE=UTC
