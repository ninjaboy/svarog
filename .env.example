# Anthropic API key (for Concierg classifier)
ANTHROPIC_API_KEY=sk-ant-...

# Telegram Bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Allowed Telegram user IDs (comma-separated)
TELEGRAM_ALLOWED_USERS=123456789

# Projects directory to scan
PROJECTS_DIR=~/projects

# Database path
DB_PATH=./data/conciergon.db

# Watchdog poll interval in ms
WATCHDOG_INTERVAL_MS=1500

# Worker idle timeout in seconds (alert after this)
WORKER_IDLE_TIMEOUT_S=300

# Log level
LOG_LEVEL=info
