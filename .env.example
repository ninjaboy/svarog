# Authentication (choose one):
# Option 1: OAuth token (recommended — run `claude login` first, then copy token)
# ANTHROPIC_AUTH_TOKEN=sk-ant-oat01-...
# Option 2: API key
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Telegram Bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Allowed Telegram user IDs (comma-separated)
TELEGRAM_ALLOWED_USERS=123456789

# Projects directory to scan
PROJECTS_DIR=~/projects

# Database path
DB_PATH=./data/conciergon.db

# Health endpoint port
HEALTH_PORT=3847

# Worker timeouts
WATCHDOG_INTERVAL_MS=1500
WORKER_IDLE_TIMEOUT_S=300
WORKER_SESSION_TIMEOUT_S=7200
WORKER_RESUME_MAX_AGE_S=3600

# Log level (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info

# Timezone for scheduled tasks (e.g., America/New_York, Europe/London)
USER_TIMEZONE=UTC
